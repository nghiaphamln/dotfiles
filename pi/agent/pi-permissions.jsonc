{
  // Conservative global policy for pi-permission-system.
  // Keep routine exploration quiet, ask before mutation/network/shell, and hard-deny obvious secrets.
  "defaultPolicy": {
    "tools": "ask",
    "bash": "ask",
    "mcp": "ask",
    "skills": "ask",
    "special": "ask"
  },
  "tools": {
    "*": "ask",
    "read": "allow",
    "grep": "allow",
    "find": "allow",
    "ls": "allow",
    "write": "ask",
    "edit": "ask",
    "bash": "ask",

    "read:*/.env*": "deny",
    "read:*/*.pem": "deny",
    "read:*/*.key": "deny",
    "read:*/id_rsa*": "deny",
    "read:*/auth.json": "deny",
    "write:*/.env*": "deny",
    "write:*/*.pem": "deny",
    "write:*/*.key": "deny",
    "write:*/id_rsa*": "deny",
    "write:*/auth.json": "deny",
    "edit:*/.env*": "deny",
    "edit:*/*.pem": "deny",
    "edit:*/*.key": "deny",
    "edit:*/id_rsa*": "deny",
    "edit:*/auth.json": "deny"
  },
  "bash": {
    "*": "ask",
    "rm -rf *": "deny",
    "git reset --hard*": "deny",
    "git clean -fd*": "deny",
    "git push --force*": "deny",
    "sudo *": "deny",
    "curl *|*sh*": "deny",
    "wget *|*sh*": "deny"
  },
  "mcp": {
    "*": "ask"
  },
  "skills": {
    "*": "ask"
  },
  "special": {
    "external_directory": "ask",
    "doom_loop": "deny"
  }
}
