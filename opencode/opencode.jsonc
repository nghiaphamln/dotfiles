{
  "$schema": "https://opencode.ai/config.json",
  "model": "aicheap/gpt-5.5",
  "small_model": "aicheap/gpt-5.4",
  "instructions": [
    "skills/iron-laws.md"
  ],
  "plugin": [],
  "provider": {
    "aicheap": {
      "name": "AI Cheap Provider",
      "options": {
        "baseURL": "{env:AI_CHEAP_API_KEY}",
        "apiKey": "{env:AI_CHEAP_API_KEY}"
      },
      "models": {
        "gpt-5.5": {
          "name": "GPT 5.5",
